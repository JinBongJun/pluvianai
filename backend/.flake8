[flake8]
max-line-length = 120
extend-ignore =
    E203
    W503
    E501
# Notes:
# - E203 and W503 are ignored to align with Black's formatting style.
# - E501 is effectively handled by the max-line-length setting above.
exclude =
    .git,
    __pycache__,
    build,
    dist,
    *.egg-info,
    .venv,
    venv,
    env,
    migrations,
    alembic
per-file-ignores =
    __init__.py:F401
