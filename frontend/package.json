{
  "name": "agentguard-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit --skipLibCheck",
    "generate-types": "npx openapi-typescript http://localhost:8000/openapi.json -o lib/api-types.ts",
    "validate-types": "npm run generate-types && npm run type-check"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.32.1",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "14.0.3",
    "postcss": "^8.4.32",
    "posthog-js": "^1.328.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "eslint": "^8.54.0",
    "eslint-config-next": "14.0.3",
    "openapi-typescript": "^7.4.3"
  }
}
