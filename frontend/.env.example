# AgentGuard Frontend - Environment Variables
# Copy to .env.local and set values

# Backend API URL (required)
# - Railway: https://your-backend.up.railway.app (from Railway → Backend → Settings → Public Domain)
# - Local backend: http://localhost:8000 or http://localhost:8888
NEXT_PUBLIC_API_URL=http://localhost:8000

# PostHog (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
