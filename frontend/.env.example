# AgentGuard Frontend - Environment Variables
# Copy to .env.local and set values

# Backend API URL (required) — 로그인과 모든 API가 이 주소로 갑니다. 반드시 하나만 사용하세요.
# - Railway 사용: Railway 대시보드 → Backend 서비스 → Settings → Public Domain URL 복사 후 아래에 붙여넣기
#   예: NEXT_PUBLIC_API_URL=https://agentguard-backend-production.up.railway.app
# - 로컬 백엔드만 사용: http://localhost:8000 (로컬 DB에 테스트 계정이 있어야 함)
# 변경 후 반드시 dev 서버 재시작 (npm run dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# PostHog (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
