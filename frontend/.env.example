# PluvianAI Frontend - Environment Variables
# Copy to .env.local and set values

# Backend API URL (required) — login and all API requests use this address. Set only one value.
# - Railway: Open Railway dashboard -> Backend service -> Settings -> copy Public Domain URL and paste below.
#   Example: NEXT_PUBLIC_API_URL=https://api.pluvianai.com
# - Local backend only: http://localhost:8000 (requires test accounts in the local DB)
# Restart dev server after changes (npm run dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# PostHog (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Paddle checkout (required for hosted payment links / modal checkout)
# - Client-side token from Paddle Developer Tools -> Authentication
# - Use "production" for live, "sandbox" for test mode
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=production
