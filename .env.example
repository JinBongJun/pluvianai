# PluvianAI Environment Variables Example
# Copy this file to .env and fill in your actual values

# Application
APP_NAME=PluvianAI API
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=production
PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pluvianai

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_POLICY_MIN_LENGTH=12
ENABLE_HIBP_CHECK=false
RECAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5

# CORS
CORS_ORIGINS=https://your-frontend-domain.com

# API Keys (for LLM providers - optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Frontend Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Email configuration (Resend)
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=PluvianAI
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
FEEDBACK_TO_EMAIL=
# If set, in-app feedback is sent to this Slack Incoming Webhook instead of Resend
FEEDBACK_SLACK_WEBHOOK_URL=
# Optional: Bot Token (xoxb-...) and channel ID (e.g. C01234567) to upload feedback attachments to Slack (scope: files:write)
FEEDBACK_SLACK_BOT_TOKEN=
FEEDBACK_SLACK_CHANNEL_ID=

# Slack configuration
SLACK_WEBHOOK_URL=
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_COOLDOWN_SECONDS=600

# Ops alert tuning profile (recommended baseline for ~1,000 paid users)
# Keep windows long enough to absorb burst noise, but short enough for actionable alerts.
OPS_LIVE_VIEW_WINDOW_SECONDS=300
OPS_LIVE_VIEW_5XX_RATE_THRESHOLD=0.05
OPS_LIVE_VIEW_P95_MS_THRESHOLD=3000
OPS_PROJECT_API_WINDOW_SECONDS=300
OPS_PROJECT_API_MIN_SAMPLES=20
OPS_PROJECT_API_5XX_RATE_THRESHOLD=0.05
OPS_PROJECT_API_P95_MS_THRESHOLD=3000
OPS_RELEASE_GATE_WINDOW_SECONDS=600
OPS_RELEASE_GATE_FAILURE_BURST_COUNT=3
OPS_RELEASE_GATE_RATIO_WINDOW_SECONDS=3600
OPS_RELEASE_GATE_RATIO_MIN_SAMPLES=10
OPS_RELEASE_GATE_FAIL_RATIO_THRESHOLD=0.15
OPS_PROVIDER_ERROR_WINDOW_SECONDS=600
OPS_PROVIDER_ERROR_BURST_COUNT=5
OPS_DB_ERROR_WINDOW_SECONDS=300
OPS_DB_ERROR_BURST_COUNT=10
OPS_SNAPSHOT_WINDOW_SECONDS=600
OPS_SNAPSHOT_5XX_RATIO_THRESHOLD=0.20
OPS_SNAPSHOT_ERROR_MIN_SAMPLES=20
OPS_ALERT_META_WINDOW_SECONDS=3600
OPS_ALERT_META_FREQUENCY_THRESHOLD=20

# Encryption for user API keys
ENCRYPTION_KEY=

# Paddle Billing (https://developer.paddle.com/)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_USE_SANDBOX=true
PADDLE_PRICE_ID_STARTER=
PADDLE_PRICE_ID_INDIE=
PADDLE_PRICE_ID_STARTUP=
PADDLE_PRICE_ID_PRO=
PADDLE_PRICE_ID_ENTERPRISE=

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Free Plan Limits
ENABLE_FREE_PLAN_HARD_LIMIT=false

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Feature Flags
FEATURE_FLAG_NEW_DASHBOARD=false
FEATURE_FLAG_ENHANCED_ANALYTICS=false
FEATURE_FLAG_BETA_FEATURES=false
FEATURE_FLAG_EXPERIMENTAL_API=false

# Monitoring (optional)
GRAFANA_URL=
PROMETHEUS_URL=
# When ENVIRONMENT=production, GET /metrics is off unless set true (needed for Prometheus scrape)
EXPOSE_METRICS_ENDPOINT=true
