# AgentGuard Environment Variables Example
# Copy this file to .env and fill in your actual values

# Application
APP_NAME=AgentGuard API
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=production
PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agentguard

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_POLICY_MIN_LENGTH=12
ENABLE_HIBP_CHECK=false
RECAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5

# CORS
CORS_ORIGINS=https://your-frontend-domain.com

# API Keys (for LLM providers - optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Frontend Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Email configuration (Resend)
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=AgentGuard

# Slack configuration
SLACK_WEBHOOK_URL=

# Encryption for user API keys
ENCRYPTION_KEY=

# Stripe configuration (Billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_INDIE=
STRIPE_PRICE_ID_STARTUP=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=

# Free Plan Limits
ENABLE_FREE_PLAN_HARD_LIMIT=false

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Feature Flags
FEATURE_FLAG_NEW_DASHBOARD=false
FEATURE_FLAG_ENHANCED_ANALYTICS=false
FEATURE_FLAG_BETA_FEATURES=false
FEATURE_FLAG_EXPERIMENTAL_API=false

# Monitoring (optional)
GRAFANA_URL=
PROMETHEUS_URL=
